# ==============================================================================
# CampusPulse — Environment Configurations Template (.env.example)
# Rename this file to '.env' and populate the variables before starting services.
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend API & WebSocket Server Config
# ------------------------------------------------------------------------------
PORT=5000
NODE_ENV=production
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Database & Cache Connection Strings
# ------------------------------------------------------------------------------
# PostgreSQL database URI (e.g. Neon, Supabase, or self-hosted)
DATABASE_URL=postgresql://user:password@localhost:5432/campuspulse

# Redis connection URI (used for auth caching, chat rooms, and matchmaking queues)
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------------------
# Cryptography & Token Signers
# ------------------------------------------------------------------------------
# High-entropy keys used to sign access and refresh session tokens
JWT_ACCESS_SECRET=your_jwt_access_token_signing_secret_key_change_me
JWT_REFRESH_SECRET=your_jwt_refresh_token_signing_secret_key_change_me

# Cryptographic salt used for computing one-way HMAC signatures.
# This prevents linking user IDs to anonymous postings and comments in DB logs.
ANON_SECRET_SALT=your_cryptographic_confession_salt_key_change_me

# ------------------------------------------------------------------------------
# Email Dispatcher Integration (Resend API)
# ------------------------------------------------------------------------------
# If left commented out or blank, the API server defaults to DEV AUTH mode,
# printing the 6-digit magic login codes in the terminal logs and returning them in payloads.
# RESEND_API_KEY=re_123456789abcdef
# EMAIL_FROM=CampusPulse <noreply@campuspulse.edu>

# ------------------------------------------------------------------------------
# Mobile Client Config (Expo)
# ------------------------------------------------------------------------------
# Target API Server URL. Expo client bundles read this variable at package/build time
# to resolve endpoints correctly. Include protocol and port.
EXPO_PUBLIC_API_URL=http://localhost:5000
